<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!-- 개정이력: 2026.06.17  구재호  Spring Boot + Thymeleaf 전환 / TB_ 표준 명명 적용 -->
<mapper namespace="bannerDAO">


    <resultMap id="banner" type="egovframework.let.uss.ion.bnr.service.BannerVO">
        <result property="bannerId" column="BANNER_ID"/>
        <result property="bannerNm" column="BANNER_NM"/>
        <result property="linkUrl" column="LINK_URL"/>
        <result property="bannerImage" column="BANNER_IMAGE"/>
        <result property="bannerImageFile" column="BANNER_IMAGE_FILE"/>
        <result property="bannerDc" column="BANNER_DC"/>
        <result property="sortOrdr" column="SORT_ORDR"/>
        <result property="reflctAt" column="REFLCT_AT"/>
        <result property="bannerTy" column="BANNER_TY"/>
        <result property="popupLeft" column="POPUP_LEFT"/>
        <result property="popupTop" column="POPUP_TOP"/>
        <result property="popupWidth" column="POPUP_WIDTH"/>
        <result property="popupHeight" column="POPUP_HEIGHT"/>
        <result property="popupGroupAt" column="POPUP_GROUP_AT"/>
        <result property="expsrBgnde" column="EXPSR_BGNDE"/>
        <result property="expsrEndde" column="EXPSR_ENDDE"/>
        <result property="userId" column="FRST_REGISTER_ID"/>
        <result property="regDate" column="FRST_REGIST_PNTTM"/>
        <result property="lastUpdtPnttm" column="LAST_UPDT_PNTTM"/>
    </resultMap>

    <resultMap id="fileList" type="egovframework.com.cmm.service.FileVO">
        <result property="atchFileId" column="ATCH_FILE_ID"/>
        <result property="fileCn" column="FILE_CN"/>
        <result property="fileExtsn" column="FILE_EXTSN"/>
        <result property="fileMg" column="FILE_SIZE"/>
        <result property="fileSn" column="FILE_SN"/>
        <result property="fileStreCours" column="FILE_STRE_COURS"/>
        <result property="orignlFileNm" column="ORIGNL_FILE_NM"/>
        <result property="streFileNm" column="STRE_FILE_NM"/>
        <result property="creatDt" column="CREAT_DT"/>          
    </resultMap>

    <resultMap id="bannerImage" type="egovframework.let.uss.ion.bnr.service.BannerVO">
        <result property="bannerImageFile" column="BANNER_IMAGE_FILE"/>
        <result property="linkUrl" column="LINK_URL"/>
    </resultMap>

    <resultMap id="bannerImageFile" type="egovframework.com.cmm.service.FileVO">
        <result property="fileStreCours" column="FILE_STRE_COURS"/>
        <result property="streFileNm" column="STRE_FILE_NM"/>
    </resultMap>

    <select id="selectBannerList" parameterType="egovframework.let.uss.ion.bnr.service.BannerVO" resultMap="banner">
            SELECT BANNER_ID,            
                   BANNER_NM,            
                   LINK_URL,             
                   BANNER_IMAGE,       
                   BANNER_IMAGE_FILE,  
                   BANNER_DC, 
                   SORT_ORDR,
                   REFLCT_AT,
                   BANNER_TY,
                   FRST_REGISTER_ID,
                   TO_CHAR(FRST_REGIST_PNTTM,'YYYY-MM-DD') as FRST_REGIST_PNTTM
              FROM TB_BANNER
             WHERE 1=1
            <if test="searchCondition == 1">AND
                BANNER_NM LIKE CONCAT('%' , #{searchKeyword}, '%')
            </if>
            ORDER BY FRST_REGIST_PNTTM DESC
            LIMIT #{recordCountPerPage} OFFSET #{firstIndex}
    </select>

    <select id="selectBannerListByType" parameterType="egovframework.let.uss.ion.bnr.service.BannerVO" resultMap="banner">
            SELECT BANNER_ID,
                   BANNER_NM,
                   LINK_URL,
                   BANNER_IMAGE,
                   BANNER_IMAGE_FILE,
                   BANNER_DC,
                   SORT_ORDR,
                   REFLCT_AT,
                   BANNER_TY,
                   POPUP_LEFT,
                   POPUP_TOP,
                   POPUP_WIDTH,
                   POPUP_HEIGHT,
                   POPUP_GROUP_AT,
                   EXPSR_BGNDE,
                   EXPSR_ENDDE,
                   FRST_REGISTER_ID,
                   TO_CHAR(FRST_REGIST_PNTTM,'YYYY-MM-DD') as FRST_REGIST_PNTTM
              FROM TB_BANNER
             WHERE REFLCT_AT = 'Y'
               AND BANNER_TY = #{bannerTy}
               AND (EXPSR_BGNDE IS NULL OR EXPSR_BGNDE &lt;= CURRENT_DATE)
               AND (EXPSR_ENDDE IS NULL OR EXPSR_ENDDE &gt;= CURRENT_DATE)
             ORDER BY SORT_ORDR
    </select>

    <select id="selectBannerListTotCnt" parameterType="egovframework.let.uss.ion.bnr.service.BannerVO" resultType="int">

            SELECT COUNT(*) totcnt
            FROM TB_BANNER
            WHERE 1=1
            <if test="searchCondition == 1">AND
                BANNER_NM LIKE CONCAT('%' , #{searchKeyword}, '%')
            </if>
    </select>
    
    <select id="selectBanner" resultMap="banner">
        
            SELECT BANNER_ID,            
                   BANNER_NM,            
                   LINK_URL,             
                   BANNER_IMAGE,      
                   BANNER_IMAGE_FILE,   
                   BANNER_DC,
                   SORT_ORDR,
                   REFLCT_AT,
                   BANNER_TY,
                   POPUP_LEFT,
                   POPUP_TOP,
                   POPUP_WIDTH,
                   POPUP_HEIGHT,
                   POPUP_GROUP_AT,
                   EXPSR_BGNDE,
                   EXPSR_ENDDE,
                   FRST_REGISTER_ID,
                   TO_CHAR(FRST_REGIST_PNTTM,'YYYY-MM-DD') as FRST_REGIST_PNTTM,
                   TO_CHAR(LAST_UPDT_PNTTM,'YYYY-MM-DD HH24:MI:SS') as LAST_UPDT_PNTTM
              FROM TB_BANNER
             WHERE BANNER_ID = #{bannerId}

    </select>

    <insert id="insertBanner" parameterType="egovframework.let.uss.ion.bnr.service.Banner">
        
            INSERT INTO TB_BANNER
                   (BANNER_ID,
                    BANNER_NM,
                    LINK_URL,             
                    BANNER_IMAGE,   
                    BANNER_IMAGE_FILE,      
                    BANNER_DC,    
                    SORT_ORDR,
                    REFLCT_AT,
                    BANNER_TY,
                    POPUP_LEFT,
                    POPUP_TOP,
                    POPUP_WIDTH,
                    POPUP_HEIGHT,
                    POPUP_GROUP_AT,
                    EXPSR_BGNDE,
                    EXPSR_ENDDE,
                    FRST_REGISTER_ID,
                    FRST_REGIST_PNTTM)
            VALUES (#{bannerId},
                    #{bannerNm},
                    #{linkUrl},
                    #{bannerImage},
                    #{bannerImageFile},
                    #{bannerDc},
                    #{sortOrdr},
                    #{reflctAt},
                    #{bannerTy},
                    #{popupLeft},
                    #{popupTop},
                    #{popupWidth},
                    #{popupHeight},
                    #{popupGroupAt},
                    <choose><when test="expsrBgnde != null and expsrBgnde != ''">CAST(#{expsrBgnde} AS DATE)</when><otherwise>NULL</otherwise></choose>,
                    <choose><when test="expsrEndde != null and expsrEndde != ''">CAST(#{expsrEndde} AS DATE)</when><otherwise>NULL</otherwise></choose>,
                    #{userId},
                    now())

    </insert>

    <update id="updateBanner" parameterType="egovframework.let.uss.ion.bnr.service.Banner">
            UPDATE TB_BANNER
               SET BANNER_NM = #{bannerNm},
                   LINK_URL = #{linkUrl},
                   <if test="isAtchFile == true">
                   BANNER_IMAGE = #{bannerImage},
                   BANNER_IMAGE_FILE = #{bannerImageFile},
                   </if>
                   BANNER_DC = #{bannerDc},
                   SORT_ORDR = #{sortOrdr},
                   REFLCT_AT = #{reflctAt},
                   BANNER_TY = #{bannerTy},
                   POPUP_LEFT = #{popupLeft},
                   POPUP_TOP = #{popupTop},
                   POPUP_WIDTH = #{popupWidth},
                   POPUP_HEIGHT = #{popupHeight},
                   POPUP_GROUP_AT = #{popupGroupAt},
                   EXPSR_BGNDE = <choose><when test="expsrBgnde != null and expsrBgnde != ''">CAST(#{expsrBgnde} AS DATE)</when><otherwise>NULL</otherwise></choose>,
                   EXPSR_ENDDE = <choose><when test="expsrEndde != null and expsrEndde != ''">CAST(#{expsrEndde} AS DATE)</when><otherwise>NULL</otherwise></choose>,
                   LAST_UPDUSR_ID = #{userId},
                   LAST_UPDT_PNTTM = now()
             WHERE BANNER_ID = #{bannerId}
    </update>
    
    <delete id="deleteBanner" parameterType="egovframework.let.uss.ion.bnr.service.Banner">
        
            DELETE FROM TB_BANNER
             WHERE BANNER_ID = #{bannerId}    
        
    </delete>  
            
    <select id="selectBannerResult" resultMap="bannerImage">
        
            SELECT BANNER_IMAGE_FILE,
                   LINK_URL
              FROM TB_BANNER
             WHERE REFLCT_AT = 'Y'  
             ORDER BY SORT_ORDR 
        
    </select>

    <select id="selectBannerFile" parameterType="egovframework.let.uss.ion.bnr.service.Banner" resultMap="bannerImageFile">
        
            SELECT B.FILE_STRE_COURS AS FILE_STRE_COURS,
                   B.STRE_FILE_NM AS STRE_FILE_NM
              FROM TB_BANNER A,
                   TB_FILE_DETAIL B
             WHERE 1 = 1
               AND A.BANNER_ID = #{bannerId}
               AND A.BANNER_IMAGE_FILE = B.ATCH_FILE_ID  
        
    </select>
</mapper>